{
  "version": 1,
  "suites": [
    {
      "id": "portal-smoke",
      "definition": "suites/portal-smoke.json",
      "description": "Authenticated portal, gateway, console, and responsive-layout checks",
      "cases": ["portal.authenticated-page", "portal.project-thread-selectors", "portal.layout-toggle"],
      "destructive": false
    },
    {
      "id": "project-device-controls",
      "definition": "suites/project-device-controls.json",
      "description": "Project-scoped USB, serial, BLE, and identity control checks without opening a chooser",
      "cases": [
        "device.configured-profile",
        "device.configured-runtime",
        "device.configured-usb-policy",
        "device.configured-flash-guard",
        "device.unconfigured-runtime-guards",
        "device.unconfigured-usb-guards",
        "device.unconfigured-flash-guard"
      ],
      "destructive": false
    },
    {
      "id": "project-selection-diagnostic",
      "definition": "suites/project-selection-diagnostic.json",
      "description": "Project and active-thread selection settlement checks without device actions",
      "cases": [
        "selection.configured-project",
        "selection.configured-thread",
        "selection.unconfigured-project",
        "selection.unconfigured-thread"
      ],
      "destructive": false
    },
    {
      "id": "project-selection-tablet-diagnostic",
      "definition": "suites/project-selection-tablet-diagnostic.json",
      "description": "Isolated tablet project and active-thread selection checks",
      "cases": ["selection.tablet-configured", "selection.tablet-unconfigured"],
      "destructive": false
    },
    {
      "id": "unconfigured-control-diagnostic",
      "definition": "suites/unconfigured-control-diagnostic.json",
      "description": "Separates unconfigured profile, disabled-state, and console assertions",
      "cases": [
        "unconfigured.ble-profile",
        "unconfigured.ble-disabled",
        "unconfigured.usb-profile",
        "unconfigured.usb-disabled",
        "unconfigured.flash-profile",
        "unconfigured.flash-disabled",
        "unconfigured.console"
      ],
      "destructive": false
    }
  ]
}
