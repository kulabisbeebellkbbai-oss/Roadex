{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://roadex.home.arpa/schemas/client-test-manifest.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "suites"],
  "properties": {
    "version": { "const": 1 },
    "suites": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "definition", "description", "cases", "destructive"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Za-z0-9._-]{1,64}$" },
          "definition": { "type": "string", "pattern": "^suites/[A-Za-z0-9._-]{1,64}\\.json$" },
          "description": { "type": "string", "pattern": "^[ -~]{1,200}$" },
          "cases": {
            "type": "array",
            "minItems": 1,
            "maxItems": 64,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^[A-Za-z0-9._-]{1,96}$" }
          },
          "destructive": { "type": "boolean" }
        }
      }
    }
  }
}
