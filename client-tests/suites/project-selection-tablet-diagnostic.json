{
  "version": 1,
  "id": "project-selection-tablet-diagnostic",
  "viewports": ["tablet"],
  "cases": [
    {
      "id": "selection.tablet-configured",
      "steps": [
        { "action": "navigate", "path": "/Roadex", "status": 200, "cacheControl": "no-store" },
        { "action": "selectOption", "testId": "project-selector", "valueSource": "configuredProject" },
        { "action": "assertAttributeValue", "testId": "project-selector", "attribute": "data-profile-configured", "value": "true" },
        { "action": "selectFirstOption", "testId": "thread-selector", "labelPrefix": "Active" },
        { "action": "assertAttributeValue", "testId": "verify-ble", "attribute": "data-profile-configured", "value": "true" },
        { "action": "assertNoBrowserErrors" }
      ]
    },
    {
      "id": "selection.tablet-unconfigured",
      "steps": [
        { "action": "navigate", "path": "/Roadex", "status": 200, "cacheControl": "no-store" },
        { "action": "selectOption", "testId": "project-selector", "valueSource": "unconfiguredProject" },
        { "action": "assertAttributeValue", "testId": "project-selector", "attribute": "data-profile-configured", "value": "false" },
        { "action": "selectFirstOption", "testId": "thread-selector", "labelPrefix": "Active" },
        { "action": "assertAttributeValue", "testId": "verify-ble", "attribute": "data-profile-configured", "value": "false" },
        { "action": "assertNoBrowserErrors" }
      ]
    }
  ]
}
