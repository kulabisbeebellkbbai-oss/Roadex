        { "action": "assertEnabled", "testId": "observe-usb", "state": true },
        { "action": "assertAttributeValue", "testId": "verify-esp32", "attribute": "data-runtime-available", "value": "true" },
        { "action": "assertAttributeValue", "testId": "verify-esp32", "attribute": "data-policy-ready", "value": "true" },
        { "action": "assertAttributeValue", "testId": "verify-esp32", "attribute": "data-binding-ready", "value": "true" },
        { "action": "assertEnabled", "testId": "verify-esp32", "state": true },
        { "action": "assertNoBrowserErrors" }
      ]
    },
    {
      "id": "device.configured-flash-guard",
