        { "action": "assertAttributeValue", "testId": "project-selector", "attribute": "data-profile-configured", "value": "false" },
        { "action": "selectFirstOption", "testId": "thread-selector", "labelPrefix": "Active" },
        { "action": "assertEnabled", "testId": "observe-usb", "state": false },
        { "action": "assertAttributeValue", "testId": "verify-esp32", "attribute": "data-profile-configured", "value": "false" },
        { "action": "assertEnabled", "testId": "verify-esp32", "state": false },
