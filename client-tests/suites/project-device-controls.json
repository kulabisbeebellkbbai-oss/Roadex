        { "action": "assertAttributeValue", "testId": "verify-ble", "attribute": "data-runtime-available", "value": "true" },
        { "action": "assertEnabled", "testId": "verify-ble", "state": true },
        { "action": "assertAttributeValue", "testId": "verify-serial", "attribute": "data-runtime-available", "value": "true" },
        { "action": "assertEnabled", "testId": "verify-serial", "state": true },
        { "action": "assertNoBrowserErrors" }
      ]
    },
    {
