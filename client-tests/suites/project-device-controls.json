        { "action": "assertAttributeValue", "testId": "flash-firmware", "attribute": "data-firmware-ready", "value": "false" },
        { "action": "assertAttributeValue", "testId": "flash-firmware", "attribute": "data-confirmation-ready", "value": "false" },
        { "action": "assertEnabled", "testId": "flash-firmware", "state": false },
        { "action": "assertNoBrowserErrors" }
      ]
    },
    {
      "id": "device.unconfigured-runtime-guards",
      "steps": [
        { "action": "navigate", "path": "/Roadex", "status": 200, "cacheControl": "no-store" },
        { "action": "selectOption", "testId": "project-selector", "valueSource": "unconfiguredProject" },
        { "action": "assertAttributeValue", "testId": "project-selector", "attribute": "data-profile-configured", "value": "false" },
        { "action": "selectFirstOption", "testId": "thread-selector", "labelPrefix": "Active" },
