{
  "version": 1,
  "id": "project-device-controls",
  "viewports": ["desktop"],
  "cases": [
    {
      "id": "device.configured-profile",
      "steps": [
        { "action": "navigate", "path": "/Roadex", "status": 200, "cacheControl": "no-store" },
        { "action": "selectOption", "testId": "project-selector", "valueSource": "configuredProject" },
        { "action": "assertAttributeValue", "testId": "project-selector", "attribute": "data-profile-configured", "value": "true" },
        { "action": "selectFirstOption", "testId": "thread-selector", "labelPrefix": "Active" },
        { "action": "assertAttributeValue", "testId": "verify-serial", "attribute": "data-profile-configured", "value": "true" },
        { "action": "assertAttributeValue", "testId": "observe-usb", "attribute": "data-profile-configured", "value": "true" },
        { "action": "assertAttributeValue", "testId": "verify-esp32", "attribute": "data-profile-configured", "value": "true" },
        { "action": "assertAttributeValue", "testId": "flash-firmware", "attribute": "data-profile-configured", "value": "true" },
        { "action": "assertNoBrowserErrors" }
      ]
    },
    {
      "id": "device.configured-runtime",
